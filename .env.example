# LedgerOne environment configuration
# Copy to .env.local and fill in. Single-tenant, personal use.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is used only in server-side admin scripts. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (required for categorization suggestions + NL queries) ---
# The AI suggests. Deterministic code handles money. See Section 4 of the README.
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to a current Claude model in code.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Stripe (Phase 4, optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- App ---
# The single business this instance keeps books for (seeded by migration).
NEXT_PUBLIC_DEFAULT_BUSINESS_SLUG=passagelab
